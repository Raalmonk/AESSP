# AESSP data products
# Raw API dumps and manually curated private tables can be large or licensing-sensitive.
data/raw/
data/cache/
data/private/

# Keep processed/reports tracked only when intentionally exported.
# Remove the next two lines if you decide to version small processed snapshots.
data/processed/*.csv
data/reports/*.csv
data/reports/*.md

# Protein sequences and raw FASTA exports should be reviewed before sharing.
*.fasta
*.fa
*.faa

